# Runtime
REDIS_URL=redis://redis:6379/0
LOCAL_TIMEZONE=America/New_York

# State / security
DATABASE_PATH=/app/data/assistant.db
ENCRYPTION_KEY_PATH=/app/data/secret.key
CHECKPOINT_OVERLAP_MINUTES=10
LOOKBACK_DAYS=30
GMAIL_PAGE_SIZE=100
GMAIL_MAX_PAGES=10
GMAIL_PENDING_THREAD_LIMIT=200
GMAIL_THREAD_CONTEXT_MAX_MESSAGES=0

# Model
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
LLM_MONTHLY_BUDGET_USD=20

# Delivery
DIGEST_EMAIL_TO=
DIGEST_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
DELIVERY_EMAIL_ENABLED=false
DELIVERY_SMS_ENABLED=false

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_TO=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN_WORK=
GOOGLE_REFRESH_TOKEN_PERSONAL=
GOOGLE_CALENDAR_IDS=

# GitHub
GITHUB_TOKEN=
GITHUB_ORG=Network-Craze

# Hedy
HEDY_API_BASE_URL=https://api.hedy.bot
HEDY_API_KEY=

# Supabase / web UI sync
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Local bootstrap behavior
SEED_MOCK_DATA_IF_EMPTY=true
